APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=https://6943-2407-d000-704-d051-c828-b95-326b-8f2e.ngrok-free.app

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=subscriptionapp
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"


SHOPIFY_APP_NAME="${APP_NAME}"
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_API_SCOPES=read_analytics,read_app_proxy,write_app_proxy,read_channels,write_channels,write_checkouts,read_checkouts,write_inventory,read_inventory,write_marketing_events,read_marketing_events,read_markets,write_markets,read_payment_terms,write_payment_terms,read_payment_customizations,write_payment_customizations,read_product_feeds,write_product_feeds,read_product_listings,write_product_listings,read_products,write_products,write_reports,read_content,write_content,unauthenticated_write_checkouts,unauthenticated_read_checkouts,unauthenticated_write_customers,unauthenticated_read_customers,unauthenticated_read_content
SHOPIFY_API_VERSION=2026-01
SHOPIFY_API_REDIRECT=/authenticate
SHOPIFY_WEBHOOK_APP_UNINSTALLED_TOPIC=APP_UNINSTALLED
SHOPIFY_WEBHOOK_APP_UNINSTALLED_ADDRESS="${APP_URL}/webhook/app-uninstalled"
SHOPIFY_FRONTEND_TYPE=SPA
SHOPIFY_THEME_BLOCK_HANDLE=subscription-widget
SHOPIFY_SUBSCRIPTION_MANAGEMENT_SETTINGS_URL=
SESSION_TOKEN_REFRESH_INTERVAL=2000
